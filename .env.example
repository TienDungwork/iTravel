# =============================================
# iTravel - Environment Variables
# =============================================
# Copy file này thành .env.local rồi điền giá trị thực
# File .env.local đã được .gitignore → an toàn, không bị commit
# =============================================

# ── MongoDB ──────────────────────────────────
# Atlas : mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/itravel
# Local : mongodb://localhost:27017/itravel
# Docker: mongodb://localhost:27017/itravel  (dùng docker-compose up -d)
MONGODB_URI=mongodb://localhost:27017/itravel

# ── NextAuth.js ──────────────────────────────
# SECRET: Bắt buộc cho production. Tạo bằng:  openssl rand -base64 32
# URL   : Chỉ cần set khi deploy (Vercel tự detect), local tự nhận localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret-string
NEXTAUTH_URL=http://localhost:3000

# ── Gemini API ───────────────────────────────
# Dùng cho AI Chat & AI Itinerary (gemini-2.5-flash)
# Tạo key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyCwddMlkzEGl0bRtOAOus-96GWpqzlKnCY
